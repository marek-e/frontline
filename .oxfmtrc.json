{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "sortPackageJson": false,
  "sortImports": true,
  "sortTailwindcss": true,
  "ignorePatterns": ["node_modules", "dist", ".output", "coverage", "pnpm-lock.yaml"]
}
