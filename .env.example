# Cloudflare (deploy — set as GitHub secrets)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Web API URL — set as a GitHub environment *variable* (not secret), baked in at Vite build time
VITE_API_URL=https://frontline-api.YOUR_SUBDOMAIN.workers.dev

# PartyKit (deploy — set as GitHub secret)
PARTYKIT_TOKEN=

# Database — Neon Postgres connection string (required by packages/db)
DATABASE_URL=

# Auth — better-auth secret (required by packages/auth)
AUTH_SECRET=
